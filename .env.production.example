# ==============================================
# BACKEND — Server
# ==============================================
PORT=3001
PAYMENT_SERVER_PORT=3002
NODE_ENV=production

# Backend URL (used for OAuth callbacks, agent card, etc.)
APP_URL=http://YOUR_VM_IP

# Frontend URL (CORS origin)
FRONTEND_URL=http://YOUR_VM_IP

# ==============================================
# BACKEND — MongoDB (external)
# ==============================================
MONGODB_URI=mongodb://YOUR_MONGO_HOST:27017/x402

# ==============================================
# BACKEND — JWT
# ==============================================
JWT_SECRET=CHANGE_ME_RANDOM_SECRET

# ==============================================
# BACKEND — Shopify OAuth
# ==============================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# ==============================================
# BACKEND — Wallet / Payment (BITE V2 Sandbox)
# ==============================================
ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
X402_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS
ETH_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS
X402_CHAIN=bite-v2-sandbox
X402_CURRENCY=USDC

# ==============================================
# BACKEND — ERC-8004 Trustless Agents
# ==============================================
ERC8004_AGENT_ID=0

# ==============================================
# FRONTEND — Build args (NEXT_PUBLIC_* baked at build time)
# ==============================================
NEXT_PUBLIC_API_URL=http://YOUR_VM_IP
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_X402_CHAIN=bite-v2-sandbox
NEXT_PUBLIC_X402_CURRENCY=USDC
