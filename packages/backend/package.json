{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express backend service",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:payment": "tsx watch src/payment-service.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:payment\"",
    "build": "tsc && node scripts/fix-imports.js",
    "start": "node dist/index.js",
    "start:payment": "node dist/payment-service.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:payment\"",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test:resource": "bun run src/test-x402-resource.ts",
    "test:resources": "bun run src/test-resources.ts",
    "test:complete": "bun run src/test-complete-flow.ts",
    "test:flow": "bun run src/test-x402-flow.ts",
    "test:orders": "bun run src/test-order-creation.ts",
    "test:eth": "tsx src/test-eth-x402.ts",
    "buy:eth": "tsx src/buy-product-eth.ts",
    "test:resource-mnt": "tsx src/test/test-resource.ts",
    "test:api-mnt": "tsx src/test/test-api.ts",
    "test:all-mnt": "tsx src/test/run-all-tests.ts",
    "test:update-prices": "tsx src/test/update-prices.ts",
    "test:all-purchases": "tsx src/test-all-purchases.ts",
    "status": "tsx src/check-status.ts",
    "view:orders": "bun run src/view-orders.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.1",
    "@supabase/supabase-js": "^2.80.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.2",
    "multer": "^1.4.5-lts.1",
    "viem": "2.44.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mongodb": "^4.0.7",
    "@types/mongoose": "^5.11.96",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
